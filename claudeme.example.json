{
  "default": "my-model",
  "models": {
    "my-model": {
      "name": "我的模型",
      "api_base": "https://your-api-provider.com/v1",
      "api_key": "$CLAUDEME_API_KEY",
      "model": "your-model-name",
      "max_tokens": 32000,
      "capabilities": {
        "vision": true,
        "tool_calling": true
      }
    },
    "my-fast-model": {
      "name": "我的快速模型",
      "api_base": "https://your-api-provider.com/v1",
      "api_key": "$CLAUDEME_API_KEY",
      "model": "your-fast-model-name",
      "max_tokens": 32000,
      "capabilities": {
        "vision": false,
        "tool_calling": true
      }
    }
  }
