{
  "default": "example-provider/default-model",
  "providers": {
    "example-provider": {
      "name": "Example Provider",
      "api_base": "https://your-api-provider.com/v1",
      "api_key": "$CLAUDEME_API_KEY",
      "models": {
        "default-model": {
          "name": "默认模型",
          "model": "your-model-name",
          "max_tokens": 32000,
          "capabilities": {
            "vision": true,
            "tool_calling": true
          }
        },
        "fast-model": {
          "name": "快速模型",
          "model": "your-fast-model-name",
          "max_tokens": 32000,
          "capabilities": {
            "vision": false,
            "tool_calling": true
          }
        }
      }
    },
    "another-provider": {
      "name": "Another Provider",
      "api_base": "https://api.example.com/v1",
      "api_key": "$ANOTHER_PROVIDER_API_KEY",
      "models": {
        "chat-model": {
          "name": "聊天模型",
          "model": "provider-chat-model",
          "max_tokens": 32000,
          "capabilities": {
            "vision": false,
            "tool_calling": true
          }
        }
      }
    }
  },
  "wiki": {
    "sources": [
      "/path/to/your/knowledge-base"
    ],
    "model": "example-provider/fast-model"
  }
}
